# Copy to `.env.local` for local builds. For GitHub Pages, use repository Secrets (see README).

# Google AdSense publisher id (looks like ca-pub-1234567890123456)
VITE_ADSENSE_CLIENT=

# Display ad unit IDs (AdSense » Ads » By ad unit)
VITE_ADSENSE_SIDEBAR=
VITE_ADSENSE_IN_ARTICLE=

# GitHub Pages project site URL is https://<user>.github.io/<repo>/  → base must match:
# VITE_SITE_BASE=/your-repo-name/

# Custom domain served at apex (https://quotes.example.com/) → leave unset or use:
# VITE_SITE_BASE=/
